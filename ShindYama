--           FUNCTIONS
-- ╚══════════════════════════════╝

local function setStatus(msg, color)
	statusLabel.Text = msg
	statusLabel.TextColor3 = color or Color3.fromRGB(120, 220, 140)
	task.delay(2.5, function()
		if statusLabel.Text == msg then statusLabel.Text = "" end
	end)
end

local function setStatusPermanent(msg, color)
	statusLabel.Text = msg
	statusLabel.TextColor3 = color or Color3.fromRGB(120, 220, 140)
end

local function simulateKeyPress(keyCode)
	VIM:SendKeyEvent(true, keyCode, false, game)
	task.wait(0.1)
	VIM:SendKeyEvent(false, keyCode, false, game)
end

local function doTeleport(loc)
	ReplicatedStorage
		:WaitForChild("Remotes")
		:WaitForChild("TeleportToPortal")
		:FireServer(loc.portal or loc.name)

	if loc.position then
		local character = player.Character or player.CharacterAdded:Wait()
		local rootPart = character:WaitForChild("HumanoidRootPart")
		local startPos = rootPart.Position
		local elapsed = 0
		repeat
			task.wait(0.1)
			elapsed += 0.1
		until (rootPart.Position - startPos).Magnitude > 10 or elapsed >= 10
		task.wait(0.5)
		rootPart.CFrame = CFrame.new(loc.position)
	end
end

local function teleportTo(loc)
	local success, err = pcall(doTeleport, loc)
	if success then
		setStatus("Teleported to " .. loc.name .. "!", Color3.fromRGB(120, 220, 140))
	else
		setStatus("Teleport failed!", Color3.fromRGB(255, 100, 100))
		warn("TeleportUI Error:", err)
	end
end

