local skills = {
	{ label = "Skill Z", key = Enum.KeyCode.Z, color = Color3.fromRGB(120, 180, 255) },
	{ label = "Skill X", key = Enum.KeyCode.X, color = Color3.fromRGB(255, 160, 80)  },
	{ label = "Skill C", key = Enum.KeyCode.C, color = Color3.fromRGB(180, 100, 255) },
	{ label = "Skill V", key = Enum.KeyCode.V, color = Color3.fromRGB(80, 220, 160)  },
	{ label = "Skill F", key = Enum.KeyCode.F, color = Color3.fromRGB(255, 80, 120)  },
}

local skillThreads = {}

local function makeSkillBtn(skill, index)
	local yPos = 50 + (index - 1) * 50

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1,-20,0,42)
	btn.Position = UDim2.new(0,10,0,yPos)
	btn.BackgroundColor3 = Color3.fromRGB(22,24,40)
	btn.TextColor3 = Color3.fromRGB(200,210,255)
	btn.Text = skill.label .. "  [OFF]"
	btn.TextSize = 13
	btn.Font = Enum.Font.GothamSemibold
	btn.BorderSizePixel = 0
	btn.AutoButtonColor = false
	btn.Parent = skillsPanel

	local bc = Instance.new("UICorner"); bc.CornerRadius = UDim.new(0,9); bc.Parent = btn
	local bs = Instance.new("UIStroke"); bs.Color = skill.color; bs.Thickness = 1; bs.Transparency = 0.6; bs.Parent = btn
	local ba = Instance.new("Frame"); ba.Size = UDim2.new(0,3,0.6,0); ba.Position = UDim2.new(0,0,0.2,0)
	ba.BackgroundColor3 = skill.color; ba.BorderSizePixel = 0; ba.Parent = btn
	local bac = Instance.new("UICorner"); bac.CornerRadius = UDim.new(1,0); bac.Parent = ba

	local enabled = false

	btn.MouseEnter:Connect(function()
		TweenService:Create(btn,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(30,34,60)}):Play()
		TweenService:Create(bs,TweenInfo.new(0.15),{Transparency=0}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn,TweenInfo.new(0.15),{BackgroundColor3=enabled and Color3.fromRGB(28,34,55) or Color3.fromRGB(22,24,40)}):Play()
		TweenService:Create(bs,TweenInfo.new(0.15),{Transparency=0.6}):Play()
	end)

	btn.MouseButton1Click:Connect(function()
		enabled = not enabled
		if enabled then
			btn.Text = skill.label .. "  [ON]"
			btn.TextColor3 = skill.color
			btn.BackgroundColor3 = Color3.fromRGB(28,34,55)
			skillThreads[index] = task.spawn(function()
				while enabled do
					simulateKeyPress(skill.key)
					task.wait(0.5) -- press every 0.5s, adjust per skill cooldown
				end
			end)
		else
			btn.Text = skill.label .. "  [OFF]"
			btn.TextColor3 = Color3.fromRGB(200,210,255)
			btn.BackgroundColor3 = Color3.fromRGB(22,24,40)
			enabled = false
		end
	end)
end

for i, skill in ipairs(skills) do
	makeSkillBtn(skill, i)
end

