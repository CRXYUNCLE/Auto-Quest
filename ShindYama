local AURA_MIN = 0; local AURA_MAX = 1.0; local auraInterval = 0.2; local auraEnabled = false
local dragging = false

local function updateSlider(pct)
	pct = math.clamp(pct,0,1)
	auraInterval = AURA_MAX - pct*(AURA_MAX-AURA_MIN)
	sliderFill.Size = UDim2.new(pct,0,1,0)
	sliderKnob.Position = UDim2.new(pct,0,0.5,0)
	sliderLabel.Text = auraInterval==0 and "Speed: MAX" or string.format("Speed: %.3fs",auraInterval)
end

local function getPctFromX(x)
	return math.clamp((x-sliderTrack.AbsolutePosition.X)/sliderTrack.AbsoluteSize.X,0,1)
end

