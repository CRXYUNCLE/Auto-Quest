-- Slider drag logic
local dragging = false
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local function updateSlider(pct)
	pct = math.clamp(pct, 0, 1)
	-- pct=0 -> slowest (AURA_MAX), pct=1 -> fastest (AURA_MIN)
	auraInterval = AURA_MAX - pct * (AURA_MAX - AURA_MIN)
	sliderFill.Size = UDim2.new(pct, 0, 1, 0)
	sliderKnob.Position = UDim2.new(pct, 0, 0.5, 0)
	if auraInterval == 0 then
		sliderLabel.Text = "Speed: MAX"
	else
		sliderLabel.Text = string.format("Speed: %.3fs", auraInterval)
	end
end

local function getPctFromX(x)
	local trackPos = sliderTrack.AbsolutePosition.X
	local trackSize = sliderTrack.AbsoluteSize.X
	return math.clamp((x - trackPos) / trackSize, 0, 1)
end

-- Start drag from knob
sliderKnob.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
	end
end)

-- Start drag from clicking anywhere on track
sliderTrack.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		updateSlider(getPctFromX(input.Position.X))
	end
end)

-- Touch support - start
sliderKnob.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
	end
end)

sliderTrack.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		updateSlider(getPctFromX(input.Position.X))
	end
end)

-- Update every frame while dragging (most reliable method)
RunService.RenderStepped:Connect(function()
	if dragging then
		local mousePos = UIS:GetMouseLocation()
		updateSlider(getPctFromX(mousePos.X))
	end
end)

-- Touch move
UIS.TouchMoved:Connect(function(touch)
	if dragging then
		updateSlider(getPctFromX(touch.Position.X))
	end
end)

-- Stop drag on mouse release
UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

local function runKillAura()
	while auraEnabled do
		pcall(function()
			ReplicatedStorage
				:WaitForChild("CombatSystem")
				:WaitForChild("Remotes")
				:WaitForChild("RequestHit")
				:FireServer()
		end)
		if auraInterval > 0 then
			task.wait(auraInterval)
		else
			task.wait() -- yield for 1 frame only, absolute max speed
		end
	end
end

