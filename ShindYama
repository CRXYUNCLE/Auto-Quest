-- Farm state
local farmEnabled = false
local soulcity  = locations[1]
local judgement = locations[2]

local FARM_WAIT   = 6 * 60 + 30  -- 6 minutes 30 seconds timer before going to Judgement
local RETURN_WAIT = 6             -- seconds to wait at Judgement before going back

local VIM = game:GetService("VirtualInputManager")

local function simulateKeyPress(keyCode)
	VIM:SendKeyEvent(true, keyCode, false, game)
	task.wait(0.1)
	VIM:SendKeyEvent(false, keyCode, false, game)
end

local function runFarmLoop()
	while farmEnabled do

		-- STEP 1: TP to Soul City island then position
		setStatusPermanent("Farm: Going to Soul City...", Color3.fromRGB(99, 179, 255))
		pcall(doTeleport, soulcity)
		if not farmEnabled then break end
		task.wait(0.3)

		-- STEP 2: Press 3
		simulateKeyPress(Enum.KeyCode.One)
		if not farmEnabled then break end

		-- STEP 3: Countdown 6m30s
		local remaining = FARM_WAIT
		while remaining > 0 and farmEnabled do
			local mins = math.floor(remaining / 60)
			local secs = remaining % 60
			setStatusPermanent(
				string.format("Farm: Next in %d:%02d", mins, secs),
				Color3.fromRGB(200, 100, 255)
			)
			task.wait(1)
			remaining -= 1
		end
		if not farmEnabled then break end

		-- STEP 4: TP to Judgement island then position
		setStatusPermanent("Farm: Going to Judgement...", Color3.fromRGB(255, 120, 120))
		pcall(doTeleport, judgement)
		if not farmEnabled then break end
		task.wait(0.3)

		-- STEP 5: Press 2
		simulateKeyPress(Enum.KeyCode.Two)
		if not farmEnabled then break end

		-- STEP 6: Wait 3 secs then press X
		task.wait(3)
		if not farmEnabled then break end
		simulateKeyPress(Enum.KeyCode.X)

		-- STEP 7: Wait 3 secs then press C
		task.wait(3)
		if not farmEnabled then break end
		simulateKeyPress(Enum.KeyCode.C)

		-- STEP 8: Wait 6 seconds then TP back
		local wait = RETURN_WAIT
		while wait > 0 and farmEnabled do
			setStatusPermanent(
				string.format("Farm: At Judgement, back in %ds", wait),
				Color3.fromRGB(255, 120, 120)
			)
			task.wait(1)
			wait -= 1
		end
		if not farmEnabled then break end

		-- Loop back to STEP 1
	end

	setStatusPermanent("", Color3.fromRGB(120, 220, 140))
end

