-- ╔══════════════════════════════╗
--         TOGGLE LOGIC
-- ╚══════════════════════════════╝

local isOpen = false

local function openUI()
	isOpen = true
	toggleBtn.Text = "X"
	if activeTab == "skills" then
		showSkills()
	else
		showTP()
	end
end

local function closeUI()
	isOpen = false
	toggleBtn.Text = "TP"
	TweenService:Create(tpPanel,TweenInfo.new(0.15,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Size=UDim2.new(0,panelW,0,0)}):Play()
	TweenService:Create(skillsPanel,TweenInfo.new(0.15,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Size=UDim2.new(0,panelW,0,0)}):Play()
	task.delay(0.16, function()
		if not isOpen then
			tpPanel.Visible = false
			skillsPanel.Visible = false
		end
	end)
end

toggleBtn.MouseButton1Click:Connect(function()
	if isOpen then closeUI() else openUI() end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.M then
		if isOpen then closeUI() else openUI() end
	end
end)
