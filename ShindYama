			ReplicatedStorage:WaitForChild("CombatSystem"):WaitForChild("Remotes"):WaitForChild("RequestHit"):FireServer()
		end)
		if auraInterval>0 then task.wait(auraInterval) else task.wait() end
	end
end

auraBtn.MouseEnter:Connect(function() TweenService:Create(auraBtn,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(55,22,22)}):Play(); TweenService:Create(auraS,TweenInfo.new(0.15),{Transparency=0}):Play() end)
auraBtn.MouseLeave:Connect(function()
	TweenService:Create(auraBtn,TweenInfo.new(0.15),{BackgroundColor3=auraEnabled and Color3.fromRGB(55,22,22) or Color3.fromRGB(40,18,18)}):Play()
	TweenService:Create(auraS,TweenInfo.new(0.15),{Transparency=0.6}):Play()
end)
auraBtn.MouseButton1Click:Connect(function()
