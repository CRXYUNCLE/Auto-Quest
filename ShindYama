		auraBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
		auraBtn.BackgroundColor3 = Color3.fromRGB(55, 22, 22)
		task.spawn(runKillAura)
	else
		auraBtn.Text = "Kill Aura: OFF"
		auraBtn.TextColor3 = Color3.fromRGB(160, 160, 160)
		auraBtn.BackgroundColor3 = Color3.fromRGB(40, 18, 18)
	end
end)



local isOpen = false

local function togglePanel()
	isOpen = not isOpen

	if isOpen then
		panel.Size = UDim2.new(0, 220, 0, 0)
		panel.Visible = true
		TweenService:Create(panel, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, 220, 0, panelHeight),
		}):Play()
		toggleBtn.Text = "X"
	else
		TweenService:Create(panel, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Size = UDim2.new(0, 220, 0, 0),
		}):Play()
		task.delay(0.21, function()
			if not isOpen then
				panel.Visible = false
			end
		end)
		toggleBtn.Text = "TP"
	end
end

toggleBtn.MouseButton1Click:Connect(togglePanel)

-- Press M to toggle
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.M then
		togglePanel()
	end
end)
