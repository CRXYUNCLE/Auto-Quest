local function selectAmount(amount, btn)
    selectedAmount = amount
    for _, data in ipairs(amountButtons) do
        data.btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
        data.btn.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
    btn.BackgroundColor3 = Color3.fromRGB(255, 200, 50)
    btn.TextColor3 = Color3.fromRGB(20, 20, 20)
end

