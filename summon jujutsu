-- Logic
local function updateUI()
    if running then
        startBtn.Text = "⏹  Stop"
        startBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
        statusLabel.TextColor3 = Color3.fromRGB(80, 220, 80)
        statusLabel.Text = "● Running"
    else
        startBtn.Text = "▶  Start Auto Summon"
        startBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 100)
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        statusLabel.Text = "● Stopped"
    end
end

local function autoSummon()
    while running do
        local ok, err = pcall(function()
            remote:InvokeServer(BANNER_NAME, selectedAmount)
        end)
        if ok then
            summonCount += selectedAmount
            countLabel.Text = "Summons: " .. summonCount
        else
            warn("Summon error: " .. tostring(err))
        end
        task.wait(DELAY)
    end
end

startBtn.MouseButton1Click:Connect(function()
    running = not running
    updateUI()
    if running then
        task.spawn(autoSummon)
    end
end)
