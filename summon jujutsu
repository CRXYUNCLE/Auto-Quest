    local btn = Instance.new("TextButton", slideFrame)
    btn.Size = UDim2.new(0, 52, 0, 28)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    btn.TextColor3 = Color3.fromRGB(180, 180, 180)
    btn.Text = "x" .. amount
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.BorderSizePixel = 0
    btn.LayoutOrder = i
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    table.insert(amountButtons, {btn = btn, amount = amount})

    btn.MouseButton1Click:Connect(function()
        if not running then selectAmount(amount, btn) end
    end)
end

selectAmount(10, amountButtons[1].btn)

-- Slide logic
-- Each "page" shows 4 buttons. Button width = 52, gap = 6 → step = 58*4 = 232px but
-- we just move by one button at a time for smoothness.
local STEP = 58  -- 52px button + 6px gap
local MIN_X = 24
-- Max offset: all buttons width minus visible area (scrollContainer width - 2 arrows = 240 - 48 = 192)
-- 10 buttons * 58 - 6 trailing gap = 574, visible = 192, so max scroll = 574 - 192 = 382
local MAX_SCROLL = (10 * STEP) - 6 - 192
local currentOffset = 0

local function updateSlide()
    slideFrame.Position = UDim2.new(0, MIN_X - currentOffset, 0, 0)
    leftArrow.TextTransparency = currentOffset <= 0 and 0.6 or 0
    rightArrow.TextTransparency = currentOffset >= MAX_SCROLL and 0.6 or 0
end

leftArrow.MouseButton1Click:Connect(function()
    currentOffset = math.max(0, currentOffset - STEP)
    updateSlide()
end)

rightArrow.MouseButton1Click:Connect(function()
    currentOffset = math.min(MAX_SCROLL, currentOffset + STEP)
    updateSlide()
end)

updateSlide()

-- Page dots
local dotsFrame = Instance.new("Frame", frame)
dotsFrame.Size = UDim2.new(1, -20, 0, 12)
dotsFrame.Position = UDim2.new(0, 10, 0, 180)
