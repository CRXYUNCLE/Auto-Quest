local dotsLayout = Instance.new("UIListLayout", dotsFrame)
dotsLayout.FillDirection = Enum.FillDirection.Horizontal
dotsLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
dotsLayout.VerticalAlignment = Enum.VerticalAlignment.Center
dotsLayout.Padding = UDim.new(0, 5)

-- 3 pages of ~3-4 buttons each
local dots = {}
for i = 1, 3 do
    local dot = Instance.new("Frame", dotsFrame)
    dot.Size = UDim2.new(0, 7, 0, 7)
    dot.BackgroundColor3 = i == 1 and Color3.fromRGB(255, 200, 50) or Color3.fromRGB(60, 60, 80)
    dot.BorderSizePixel = 0
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
    table.insert(dots, dot)
end

local function updateDots()
    local page = math.floor(currentOffset / (STEP * 4)) + 1
    page = math.clamp(page, 1, #dots)
    for i, dot in ipairs(dots) do
        dot.BackgroundColor3 = i == page
            and Color3.fromRGB(255, 200, 50)
            or Color3.fromRGB(60, 60, 80)
    end
end

leftArrow.MouseButton1Click:Connect(updateDots)
rightArrow.MouseButton1Click:Connect(updateDots)

