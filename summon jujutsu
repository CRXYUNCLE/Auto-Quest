-- Amount Label
local amountLabel = Instance.new("TextLabel", frame)
amountLabel.Size = UDim2.new(1, -20, 0, 20)
amountLabel.Position = UDim2.new(0, 10, 0, 82)
amountLabel.BackgroundTransparency = 1
