-- Settings
local BANNER_NAME = "Jujutsu"
local DELAY = 0.5
local running = false
local summonCount = 0
local selectedAmount = 10

local remote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("RequestBannerSummon")

